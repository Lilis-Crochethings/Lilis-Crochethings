</style>

<script>
  const listView = document.getElementById('list-view');

  const SORT_KEY = 'creations-sort-order';
  const FILTERS_KEY = 'creations-filters';

  const sortRadios = document.querySelectorAll<HTMLInputElement>('input[name="sort-order"]');
  let sortMode = 'date-desc';

  // Breaks ties on the primary sort key (same date, or same/both-unknown
  // hoursSpent) so ordering is deterministic instead of depending on
  // whatever order the items happened to already be in — always A→Z by
  // title regardless of the primary sort's own direction, so flipping
  // New→Old/Old→New doesn't also shuffle same-date items around.
  function titleTiebreak(a: HTMLElement, b: HTMLElement): number {
    return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '', undefined, { sensitivity: 'base' });
  }

  function sortContainer(container: HTMLElement | null) {
    if (!container) return;
    const [field, direction] = sortMode.split('-');
    const key = field === 'time' ? 'hours' : field === 'name' ? 'title' : 'date';
    const ascending = direction === 'asc';
    // Not container.children — CreationListItem.astro's own <script> tag
    // gets hoisted in-place as a sibling of the .list-item-wrap elements it
    // renders (Astro inlines a component's script once, at its first usage
    // in the loop), so it shows up as a non-element-with-a-dataset child
    // here. Sorting that in among real items via Number(undefined) = NaN
    // comparisons throws items near it out of order — Void Chicken sticking
    // to the top of every sort was this in action.
    const items = Array.from(container.querySelectorAll<HTMLElement>(':scope > .list-item-wrap'));
    items.sort((a, b) => {
      if (key === 'title') {
        const titleA = a.dataset.title ?? '';
        const titleB = b.dataset.title ?? '';
        const result = titleA.localeCompare(titleB, undefined, { sensitivity: 'base' });
        return ascending ? result : -result;
      }
      if (key === 'hours') {
        // No recorded hoursSpent means data-hours is omitted entirely (see
        // CreationListItem.astro), not a literal 0 — those creations always
        // sort to the end, in both directions, instead of masquerading as
        // the least time spent.
        const knownA = a.dataset.hours !== undefined;
        const knownB = b.dataset.hours !== undefined;
        if (!knownA && !knownB) return titleTiebreak(a, b);
        if (!knownA) return 1;
        if (!knownB) return -1;
      }
      const valueA = Number(a.dataset[key]);
      const valueB = Number(b.dataset[key]);
      if (valueA === valueB) return titleTiebreak(a, b);
      return ascending ? valueA - valueB : valueB - valueA;
    });
    items.forEach((item) => container.appendChild(item));
  }

  sortRadios.forEach((radio) => {
    radio.addEventListener('change', () => {
      if (!radio.checked) return;
      sortMode = radio.value;
      sessionStorage.setItem(SORT_KEY, radio.value);
      sortContainer(listView);
    });
  });

  const savedSort = sessionStorage.getItem(SORT_KEY);
  if (savedSort) {
    const radioToSelect = Array.from(sortRadios).find((radio) => radio.value === savedSort);
    if (radioToSelect) {
      radioToSelect.checked = true;
      sortMode = savedSort;
      sortContainer(listView);
    }
  }

  const DIFFICULTY_KEY = 'creations-difficulty-filters';
  const TYPE_KEY = 'creations-type-filters';
  const COLOR_KEY = 'creations-color-filters';
  const YARN_TYPE_KEY = 'creations-yarn-type-filters';

  const tagCheckboxes = document.querySelectorAll<HTMLInputElement>('.tag-filter');
  const difficultyCheckboxes = document.querySelectorAll<HTMLInputElement>('.difficulty-filter');
  const typeCheckboxes = document.querySelectorAll<HTMLInputElement>('.type-filter');
  const colorCheckboxes = document.querySelectorAll<HTMLInputElement>('.color-filter');
  const yarnTypeCheckboxes = document.querySelectorAll<HTMLInputElement>('.yarn-type-filter');
  const filtersToggle = document.getElementById('filters-toggle');
  const filtersPanel = document.getElementById('filters-panel');
  const closeFilters = document.getElementById('close-filters');
  const activeFiltersRow = document.getElementById('active-filters');
  const noResults = document.getElementById('no-results');
  const resultsCount = document.getElementById('results-count');

  function saveFilters() {
    const selected = Array.from(tagCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    sessionStorage.setItem(FILTERS_KEY, JSON.stringify(selected));
  }

  function saveDifficultyFilters() {
    const selected = Array.from(difficultyCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    sessionStorage.setItem(DIFFICULTY_KEY, JSON.stringify(selected));
  }

  function saveTypeFilters() {
    const selected = Array.from(typeCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    sessionStorage.setItem(TYPE_KEY, JSON.stringify(selected));
  }

  function saveColorFilters() {
    const selected = Array.from(colorCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    sessionStorage.setItem(COLOR_KEY, JSON.stringify(selected));
  }

  function saveYarnTypeFilters() {
    const selected = Array.from(yarnTypeCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    sessionStorage.setItem(YARN_TYPE_KEY, JSON.stringify(selected));
  }

  function applyFilters() {
    // Hiding/showing cards and resizing the active-filters/results-count row
    // above the fold shifts everything below it — without this, the browser
    // either keeps the same scrollY (so the content under the cursor jumps)
    // or its own scroll-anchoring guesses a new position (so it jumps the
    // other way). Snapshotting and restoring scrollY after every mutation
    // keeps the viewport pinned regardless of how much height changes.
    const scrollX = window.scrollX;
    const scrollY = window.scrollY;

    const selectedTags = Array.from(tagCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    const selectedDifficulties = Array.from(difficultyCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    const selectedTypes = Array.from(typeCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    const selectedColors = Array.from(colorCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    const selectedYarnTypes = Array.from(yarnTypeCheckboxes).filter((cb) => cb.checked).map((cb) => cb.value);
    filtersToggle?.classList.toggle('active', selectedTags.length > 0 || selectedDifficulties.length > 0 || selectedTypes.length > 0 || selectedColors.length > 0 || selectedYarnTypes.length > 0);
    const items = listView ? Array.from(listView.querySelectorAll<HTMLElement>(':scope > .list-item-wrap')) : [];
    let visibleCount = 0;
    for (const item of items) {
      const itemTags = (item.dataset.tags ?? '').split(' ').filter(Boolean);
      const itemTypes = (item.dataset.type ?? '').split(' ').filter(Boolean);
      const itemColors = (item.dataset.colors ?? '').split(' ').filter(Boolean);
      const itemYarnTypes = (item.dataset.yarnTypes ?? '').split(' ').filter(Boolean);
      const tagsMatch = selectedTags.length === 0 || selectedTags.some((tag) => itemTags.includes(tag));
      const difficultyMatch = selectedDifficulties.length === 0 || selectedDifficulties.includes(item.dataset.difficulty ?? '');
      const typeMatch = selectedTypes.length === 0 || selectedTypes.some((type) => itemTypes.includes(type));
      const colorMatch = selectedColors.length === 0 || selectedColors.some((color) => itemColors.includes(color));
      const yarnTypeMatch = selectedYarnTypes.length === 0 || selectedYarnTypes.some((yarnType) => itemYarnTypes.includes(yarnType));
      const visible = tagsMatch && difficultyMatch && typeMatch && colorMatch && yarnTypeMatch;
      item.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    }
    if (noResults) noResults.hidden = visibleCount > 0;
    if (resultsCount) resultsCount.textContent = `Showing ${visibleCount} of ${items.length} creations`;
    updateFilterCounts(items, selectedTags, selectedDifficulties, selectedTypes, selectedColors, selectedYarnTypes);
    renderActiveFilters();

    window.scrollTo(scrollX, scrollY);
  }

  // For every filter checkbox, shows how many creations would match if that
  // option were combined with whatever is currently selected in the *other*
  // three sections — e.g. checking "Easy" recomputes the Type/Color/Tags
  // counts to only reflect easy creations, but doesn't shrink other
  // Difficulty counts against each other, since Difficulty (like Type,
  // Color, and Tags) is a same-section OR: you're meant to compare "Easy"
  // against "Medium" and "Hard" on equal footing, not see them collapse
  // once one is picked.
  function updateFilterCounts(
    items: HTMLElement[],
    selectedTags: string[],
    selectedDifficulties: string[],
    selectedTypes: string[],
    selectedColors: string[],
    selectedYarnTypes: string[]
  ) {
    const itemData = items.map((item) => ({
      tags: (item.dataset.tags ?? '').split(' ').filter(Boolean),
      types: (item.dataset.type ?? '').split(' ').filter(Boolean),
      colors: (item.dataset.colors ?? '').split(' ').filter(Boolean),
      yarnTypes: (item.dataset.yarnTypes ?? '').split(' ').filter(Boolean),
      difficulty: item.dataset.difficulty ?? '',
    }));

    function setCount(cb: HTMLInputElement, count: number) {
      const countEl = cb.closest('label')?.querySelector<HTMLElement>('.filter-count');
      if (countEl) countEl.textContent = `(${count})`;
    }

    difficultyCheckboxes.forEach((cb) => {
      const count = itemData.filter((d) => {
        const tagsMatch = selectedTags.length === 0 || selectedTags.some((t) => d.tags.includes(t));
        const typeMatch = selectedTypes.length === 0 || selectedTypes.some((t) => d.types.includes(t));
        const colorMatch = selectedColors.length === 0 || selectedColors.some((c) => d.colors.includes(c));
        const yarnTypeMatch = selectedYarnTypes.length === 0 || selectedYarnTypes.some((y) => d.yarnTypes.includes(y));
        return d.difficulty === cb.value && tagsMatch && typeMatch && colorMatch && yarnTypeMatch;
      }).length;
      setCount(cb, count);
    });

    typeCheckboxes.forEach((cb) => {
      const count = itemData.filter((d) => {
        const tagsMatch = selectedTags.length === 0 || selectedTags.some((t) => d.tags.includes(t));
        const difficultyMatch = selectedDifficulties.length === 0 || selectedDifficulties.includes(d.difficulty);
        const colorMatch = selectedColors.length === 0 || selectedColors.some((c) => d.colors.includes(c));
        const yarnTypeMatch = selectedYarnTypes.length === 0 || selectedYarnTypes.some((y) => d.yarnTypes.includes(y));
        return d.types.includes(cb.value) && tagsMatch && difficultyMatch && colorMatch && yarnTypeMatch;
      }).length;
      setCount(cb, count);
    });

    colorCheckboxes.forEach((cb) => {
      const count = itemData.filter((d) => {
        const tagsMatch = selectedTags.length === 0 || selectedTags.some((t) => d.tags.includes(t));
        const difficultyMatch = selectedDifficulties.length === 0 || selectedDifficulties.includes(d.difficulty);
        const typeMatch = selectedTypes.length === 0 || selectedTypes.some((t) => d.types.includes(t));
        const yarnTypeMatch = selectedYarnTypes.length === 0 || selectedYarnTypes.some((y) => d.yarnTypes.includes(y));
        return d.colors.includes(cb.value) && tagsMatch && difficultyMatch && typeMatch && yarnTypeMatch;
      }).length;
      setCount(cb, count);
    });

    yarnTypeCheckboxes.forEach((cb) => {
      const count = itemData.filter((d) => {
        const tagsMatch = selectedTags.length === 0 || selectedTags.some((t) => d.tags.includes(t));
        const difficultyMatch = selectedDifficulties.length === 0 || selectedDifficulties.includes(d.difficulty);
        const typeMatch = selectedTypes.length === 0 || selectedTypes.some((t) => d.types.includes(t));
        const colorMatch = selectedColors.length === 0 || selectedColors.some((c) => d.colors.includes(c));
        return d.yarnTypes.includes(cb.value) && tagsMatch && difficultyMatch && typeMatch && colorMatch;
      }).length;
      setCount(cb, count);
    });

    tagCheckboxes.forEach((cb) => {
      const count = itemData.filter((d) => {
        const typeMatch = selectedTypes.length === 0 || selectedTypes.some((t) => d.types.includes(t));
        const difficultyMatch = selectedDifficulties.length === 0 || selectedDifficulties.includes(d.difficulty);
        const colorMatch = selectedColors.length === 0 || selectedColors.some((c) => d.colors.includes(c));
        const yarnTypeMatch = selectedYarnTypes.length === 0 || selectedYarnTypes.some((y) => d.yarnTypes.includes(y));
        return d.tags.includes(cb.value) && typeMatch && difficultyMatch && colorMatch && yarnTypeMatch;
      }).length;
      setCount(cb, count);
    });
  }

  // Builds one removable chip for a checked filter checkbox — a colored dot
  // for difficulty, an icon for a tag/type category that has one (from its
  // data-icon attribute), or just the label for a plain tag/subtype.
  function buildActiveFilterChip(cb: HTMLInputElement): HTMLElement {
    const label = cb.dataset.label ?? cb.value;
    const chip = document.createElement('span');
    chip.className = 'active-filter-chip';

    if (cb.dataset.color) {
      const dot = document.createElement('span');
      dot.className = 'active-filter-dot';
      dot.style.backgroundColor = cb.dataset.color;
      chip.appendChild(dot);
    } else if (cb.dataset.icon) {
      const icon = document.createElement('span');
      icon.className = 'active-filter-icon mask-icon';
      icon.style.maskImage = `url(${cb.dataset.icon})`;
      icon.style.setProperty('-webkit-mask-image', `url(${cb.dataset.icon})`);
      chip.appendChild(icon);
    }

    chip.append(label);

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'active-filter-remove';
    removeBtn.setAttribute('aria-label', `Remove ${label} filter`);
    // An inline SVG X, not the "✕" glyph — same trick as LightboxChrome's
    // close button. Unicode "✕" sits off-center inside its own character
    // box in most fonts, so centering the button around it still looks
    // vertically off; an SVG shape centers exactly on its viewBox.
    removeBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>';
    // Toggling via the real checkbox (not just hiding the chip) means the
    // existing change listeners do the work: cascading to children/parent,
    // saving to sessionStorage, and re-filtering the list.
    removeBtn.addEventListener('click', () => {
      cb.checked = false;
      cb.dispatchEvent(new Event('change', { bubbles: true }));
    });
    chip.appendChild(removeBtn);

    return chip;
  }

  // Renders one chip per currently-checked filter checkbox, in the same
  // order as the filter panel (Difficulty, then Type, then Tags, then Yarn
  // type, then Color) — including both a checked parent category and its
  // auto-checked children, since removing either one independently is
  // meaningful (see the cascade logic in wireParentChildCheckboxes below).
  function renderActiveFilters() {
    if (!activeFiltersRow) return;
    activeFiltersRow.innerHTML = '';
    const checked = [
      ...Array.from(difficultyCheckboxes),
      ...Array.from(typeCheckboxes),
      ...Array.from(tagCheckboxes),
      ...Array.from(yarnTypeCheckboxes),
      ...Array.from(colorCheckboxes),
    ].filter((cb) => cb.checked);
    checked.forEach((cb) => activeFiltersRow.appendChild(buildActiveFilterChip(cb)));
  }

  function getParentCheckbox(cb: HTMLInputElement, filterClass: string) {
    const parentLi = cb.closest('ul.taxonomy-children')?.parentElement;
    return parentLi?.querySelector<HTMLInputElement>(`:scope > .taxonomy-row .${filterClass}`) ?? null;
  }

  // Shared by the Tags and Type sections: checking a parent (e.g. "Crochet")
  // checks all its children ("Amigurumi", "Keychain", ...), and checking
  // every child re-checks the parent — same expand/collapse tree, just a
  // different top-level checkbox class per section.
  function wireParentChildCheckboxes(checkboxes: NodeListOf<HTMLInputElement>, filterClass: string, onChange: () => void) {
    checkboxes.forEach((cb) => {
      cb.addEventListener('change', () => {
        const childList = cb.closest('li')?.querySelector<HTMLElement>(':scope > ul.taxonomy-children');
        childList?.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((child) => {
          child.checked = cb.checked;
        });

        const parentCheckbox = getParentCheckbox(cb, filterClass);
        const siblings = parentCheckbox?.closest('li')?.querySelectorAll<HTMLInputElement>(`:scope > ul.taxonomy-children .${filterClass}`);
        if (parentCheckbox && siblings) {
          parentCheckbox.checked = Array.from(siblings).every((sibling) => sibling.checked);
        }

        onChange();
      });
    });
  }

  wireParentChildCheckboxes(tagCheckboxes, 'tag-filter', () => {
    saveFilters();
    applyFilters();
  });

  wireParentChildCheckboxes(typeCheckboxes, 'type-filter', () => {
    saveTypeFilters();
    applyFilters();
  });

  difficultyCheckboxes.forEach((cb) => {
    cb.addEventListener('change', () => {
      saveDifficultyFilters();
      applyFilters();
    });
  });

  colorCheckboxes.forEach((cb) => {
    cb.addEventListener('change', () => {
      saveColorFilters();
      applyFilters();
    });
  });

  yarnTypeCheckboxes.forEach((cb) => {
    cb.addEventListener('change', () => {
      saveYarnTypeFilters();
      applyFilters();
    });
  });

  document.getElementById('reset-filters')?.addEventListener('click', () => {
    tagCheckboxes.forEach((cb) => { cb.checked = false; });
    difficultyCheckboxes.forEach((cb) => { cb.checked = false; });
    typeCheckboxes.forEach((cb) => { cb.checked = false; });
    colorCheckboxes.forEach((cb) => { cb.checked = false; });
    yarnTypeCheckboxes.forEach((cb) => { cb.checked = false; });
    saveFilters();
    saveDifficultyFilters();
    saveTypeFilters();
    saveColorFilters();
    saveYarnTypeFilters();
    applyFilters();
  });

  document.querySelectorAll<HTMLButtonElement>('.category-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const childList = toggle.closest('li')?.querySelector<HTMLElement>(':scope > ul.taxonomy-children');
      if (!childList) return;
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      childList.classList.toggle('open', !expanded);
    });
  });

  // For categories with sub-tags, clicking the label text should expand/collapse
  // the sub-tags rather than select the tag — only the heart checkbox selects.
  document.querySelectorAll<HTMLLabelElement>('.taxonomy-row > .taxonomy-item').forEach((label) => {
    const toggle = label.parentElement?.querySelector<HTMLButtonElement>('.category-toggle');
    if (!toggle) return;
    const input = label.querySelector('input');
    label.addEventListener('click', (e) => {
      if (e.target === input) return;
      e.preventDefault();
      toggle.click();
    });
  });

  const savedFilters = sessionStorage.getItem(FILTERS_KEY);
  const savedDifficultyFilters = sessionStorage.getItem(DIFFICULTY_KEY);
  const savedTypeFilters = sessionStorage.getItem(TYPE_KEY);
  const savedColorFilters = sessionStorage.getItem(COLOR_KEY);
  const savedYarnTypeFilters = sessionStorage.getItem(YARN_TYPE_KEY);

  if (savedFilters) {
    const selected: string[] = JSON.parse(savedFilters);
    tagCheckboxes.forEach((cb) => {
      cb.checked = selected.includes(cb.value);
    });
  }

  if (savedDifficultyFilters) {
    const selected: string[] = JSON.parse(savedDifficultyFilters);
    difficultyCheckboxes.forEach((cb) => {
      cb.checked = selected.includes(cb.value);
    });
  }

  if (savedTypeFilters) {
    const selected: string[] = JSON.parse(savedTypeFilters);
    typeCheckboxes.forEach((cb) => {
      cb.checked = selected.includes(cb.value);
    });
  }

  if (savedColorFilters) {
    const selected: string[] = JSON.parse(savedColorFilters);
    colorCheckboxes.forEach((cb) => {
      cb.checked = selected.includes(cb.value);
    });
  }

  if (savedYarnTypeFilters) {
    const selected: string[] = JSON.parse(savedYarnTypeFilters);
    yarnTypeCheckboxes.forEach((cb) => {
      cb.checked = selected.includes(cb.value);
    });
  }

  // Re-open any category (Tags or Type) that was left with a checked
  // sub-item from a previous visit, regardless of which section it's in.
  document.querySelectorAll<HTMLButtonElement>('.category-toggle').forEach((toggle) => {
    const childList = toggle.closest('li')?.querySelector<HTMLElement>(':scope > ul.taxonomy-children');
    const hasCheckedChild = !!childList?.querySelector<HTMLInputElement>('input[type="checkbox"]:checked');
    if (hasCheckedChild) {
      toggle.setAttribute('aria-expanded', 'true');
      childList?.classList.add('open');
    }
  });

  // Always run once on load — besides applying any saved filters, this is
  // what draws the active-filters row's initial state.
  applyFilters();

  filtersToggle?.addEventListener('click', () => {
    filtersPanel?.classList.add('open');
    filtersToggle.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
  });

  function closeFiltersPanel() {
    filtersPanel?.classList.remove('open');
    filtersToggle?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
  }

  closeFilters?.addEventListener('click', closeFiltersPanel);

  filtersPanel?.addEventListener('click', (e) => {
    if (e.target === filtersPanel) closeFiltersPanel();
  });
</script>
