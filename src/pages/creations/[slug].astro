---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CreationCard from '../../components/creations/CreationCard.astro';
import TagChip from '../../components/creations/TagChip.astro';
import DifficultyChip from '../../components/creations/DifficultyChip.astro';
import SmartLink from '../../components/SmartLink.astro';
import LightboxChrome from '../../components/LightboxChrome.astro';
import LightboxStage from '../../components/LightboxStage.astro';
import { getCollection } from "astro:content";
import { resolveYarn } from "../../lib/yarn";
import { getEffectiveTags, getCreationAlt, getTagLabel } from "../../lib/tags";

export async function getStaticPaths() {
  const SIMILAR_LIMIT = 4;

  function seededShuffle<T>(items: T[], seed: string): T[] {
    let h = 0;
    for (let i = 0; i < seed.length; i++) h = (Math.imul(31, h) + seed.charCodeAt(i)) | 0;
    const rand = () => {
      h = Math.imul(h ^ (h >>> 15), h | 1);
      h ^= h + Math.imul(h ^ (h >>> 7), h | 61);
      return ((h ^ (h >>> 14)) >>> 0) / 4294967296;
    };

    const shuffled = [...items];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(rand() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
  }

  const creations = await getCollection("creations");
  const yarnsEntry = (await getCollection("yarns"))[0];

  return creations.map((creation) => {
    const others = creations.filter((c) => c.id !== creation.id);

    // Tags + subtypes ("amigurumi", "bag", ...) count together — not the
    // type itself ("crochet"/"embroidery" is too broad, it'd hand every
    // crochet item a free point of similarity to every other crochet item
    // regardless of actual subject matter).
    const ownTags = new Set([...(creation.data.tags ?? []), ...(creation.data.subtypes ?? [])]);
    const ownColors = new Set(creation.data.colors ?? []);
    const ownYarnTypes = new Set(creation.data.yarnTypes ?? []);
    const ownCreators = new Set((creation.data.patterns ?? []).map((g) => g.creator).filter((c) => c));
    const ownPatternNames = new Set((creation.data.patterns ?? []).flatMap((g) => g.items.map((i) => i.name)));

    // Similarity score, weighted by how strong a signal each match actually
    // is:
    //  - same literal pattern (+5): the strongest possible relation — e.g.
    //    Raytje / Raytje v2 / Raytje v3 are repeat attempts at one pattern.
    //  - same designer (+3): a good but weaker signal than the exact same
    //    pattern; can stack with it, since sharing a pattern implies sharing
    //    its designer too.
    //  - shared tags/subtypes (+1 each): the main subject-matter signal.
    //  - shared yarn material (+1 flat): uses the curated data.yarnTypes
    //    field rather than re-deriving materials from the yarn catalog, so
    //    it doesn't count a single accent color's material as equal to a
    //    piece's primary yarn.
    //  - color overlap (+0–1): scaled by how much of the *combined* palette
    //    is actually shared (Jaccard similarity) rather than a flat point
    //    per shared color, so two 1-color pieces that match fully score the
    //    same as two 4-color pieces that mostly overlap, instead of the
    //    larger palette always winning on raw shared-color count.
    // Deliberately no hook size — nearly every creation uses the same 1-2
    // sizes, so it was a coincidental match, not a real content signal.
    function similarityScore(other: (typeof others)[number]): number {
      let score = 0;

      const otherPatternNames = (other.data.patterns ?? []).flatMap((g) => g.items.map((i) => i.name));
      if (otherPatternNames.some((n) => ownPatternNames.has(n))) score += 5;

      const otherCreators = (other.data.patterns ?? []).map((g) => g.creator).filter((c) => c);
      if (otherCreators.some((c) => ownCreators.has(c!))) score += 3;

      const otherTags = [...(other.data.tags ?? []), ...(other.data.subtypes ?? [])];
      score += otherTags.filter((tag) => ownTags.has(tag)).length;

      const otherYarnTypes = other.data.yarnTypes ?? [];
      if (otherYarnTypes.some((type) => ownYarnTypes.has(type))) score += 1;

      const otherColors = other.data.colors ?? [];
      const sharedColors = otherColors.filter((color) => ownColors.has(color)).length;
      const unionColors = new Set([...ownColors, ...otherColors]).size;
      if (unionColors > 0) score += sharedColors / unionColors;

      return score;
    }

    // Shuffle first (seeded per-creation) so ties between equally-similar
    // creations land in a stable-but-varied order instead of always
    // favoring whichever comes first in the collection.
    const similar = seededShuffle(others, creation.id)
      .sort((a, b) => similarityScore(b) - similarityScore(a))
      .slice(0, SIMILAR_LIMIT);

    return {
      params: { slug: creation.id },
      props: { creation, yarnLines: yarnsEntry.data.yarns, similar },
    };
  });
}

const { creation, yarnLines, similar } = Astro.props;
const data = creation.data;

const patternCredits = data.patterns ?? [];
const firstPattern = patternCredits[0];
const firstItem = firstPattern?.items[0];

const PLATFORM_ICONS: Record<string, string> = {
  etsy: "/images/socials/etsy.webp",
  youtube: "/images/socials/youtube.webp",
  instagram: "/images/socials/instagram.webp",
  pinterest: "/images/socials/pinterest.webp",
  facebook: "/images/socials/facebook.webp",
  website: "/images/socials/website.svg",
  tiktok: "/images/socials/tiktok.svg",
  pattern: "/images/icons/pattern.svg"
};

// Etsy is a plain square logo with sharp corners in the source asset — round
// it to match the site's icon-tile convention. The others (YouTube,
// Instagram, Pinterest, Facebook) already ship their own rounded brand
// shape, so rounding them again would clip the logo. The website icon has
// no background tile to round.
const ROUNDED_PLATFORMS = new Set(["etsy"]);

// These two are plain single-color glyphs, not real brand artwork (unlike
// Etsy/YouTube/Instagram/Pinterest/Facebook/TikTok, which ship their own
// multi-color logo and must render as-is) — rendered via mask-icon +
// var(--primary) instead of a plain <img> so they stay in sync with theme
// changes rather than being frozen at whatever color is baked into the file.
const MASK_TINTED_PLATFORMS = new Set(["pattern", "website"]);

const taxonomyEntry = (await getCollection("tags"))[0];
const taxonomy = taxonomyEntry.data.tags;
const effectiveTags = getEffectiveTags(data.tags, taxonomy);

const generalEntry = (await getCollection("general"))[0];
const siteName = generalEntry.data.name;

const typesEntry = (await getCollection("types"))[0];
const typesTaxonomy = typesEntry.data.types;
const typeChipIds = [data.type, ...(data.subtypes ?? [])];
const creationAlt = getCreationAlt(data.title, data.type, data.subtypes, typesTaxonomy);

const yarnTiles = (data.yarn ?? [])
  .map((y) => resolveYarn(y, yarnLines))
  .filter((y) => y !== null)
  .sort((a, b) => (a.type ?? "").localeCompare(b.type ?? ""));

const craftType = data.type;

function isWhite(hex?: string): boolean {
  if (!hex) return false;
  const clean = hex.replace("#", "").toLowerCase();
  return clean === "fff" || clean === "ffffff";
}

const baseDescription = data.description.text || `A handmade ${craftType} ${data.title} by Lili's Crochethings.`;

// The site is branded "Crochethings," so a hand-written description that
// never happens to say "embroidery" (most don't spell out the craft at all,
// they're just describing the piece) leaves Google assuming crochet by
// default — genuinely wrong for the cross-stitch pieces. Stated every time,
// not just in the no-description fallback above.
const typeLabels = typeChipIds.map((id) => getTagLabel(id, typesTaxonomy));
const craftDescription = `Craft: ${typeLabels.join(", ")}.`;
const tagLabels = effectiveTags.map((id) => getTagLabel(id, taxonomy));

// Stated every time (not just the no-description fallback) so a pattern's
// own name and designer are always exposed here — that alone often already
// carries a searchable term (see Little Biscuit's "Corgi Puppy") without it
// having to be retyped into searchTerms too.
const patternDescription = firstItem
  ? `Pattern: "${firstItem.name}"${firstPattern?.creator ? ` by ${firstPattern.creator}` : ""}.`
  : null;

// searchTerms exist specifically for terms nothing else here already covers
// (a nickname, a broader category word) — append them rather than relying
// on prose to naturally mention every one.
const pageDescription = [
  baseDescription,
  craftDescription,
  patternDescription,
  tagLabels.length ? `Tags: ${tagLabels.join(", ")}.` : null,
  data.searchTerms?.length ? `Also known as: ${data.searchTerms.join(", ")}.` : null,
].filter(Boolean).join(" ");

const creativeWorkSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: data.title,
  description: pageDescription,
  image: data.images.map((image) => new URL(image, Astro.site).toString()),
  ...(data.date ? { dateCreated: data.date.toISOString().slice(0, 10) } : {}),
  ...(firstPattern?.creator ? { creator: { "@type": "Person", name: firstPattern.creator, ...(firstPattern.creatorLink ? { url: new URL(firstPattern.creatorLink, Astro.site).toString() } : {}) } } : {}),
  ...(firstItem ? { about: firstItem.name } : {}),
  ...(data.searchTerms?.length ? { alternateName: data.searchTerms } : {}),
  genre: typeLabels,
  ...(tagLabels.length ? { keywords: tagLabels } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Creations", item: new URL("/creations", Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: data.title, item: Astro.url.toString() },
  ],
};

// The <title> tag is the single strongest on-page signal for what a page
// ranks for — a search like "Leafeon snuggler" needs "Snuggler" to actually
// appear in it, not just in the meta description, or Google has much less
// reason to surface this page over the homepage for that query.
// Only the first searchTerm goes in the title, though — this same string is
// reused for og:title/twitter:title, so it's what shows up as the browser
// tab, the bookmark name, the headline in Google results, and the bold
// headline on every Discord/Slack/iMessage link preview. Stacking every
// searchTerm in there would clutter all of those; the full list still gets
// exposed via the meta description and JSON-LD alternateName below, neither
// of which renders as prominently.
const pageTitle = data.searchTerms?.length ? `${data.title} (${data.searchTerms[0]})` : data.title;
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={data.images[0]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(creativeWorkSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep" aria-hidden="true">/</span>
    <a href="/creations">Creations</a>
    <span class="breadcrumb-sep" aria-hidden="true">/</span>
    <span aria-current="page">{data.title}</span>
  </nav>

  <h1>{data.title}</h1>
  {data.searchTerms?.length && (
    <p class="also-known-as">{data.searchTerms.join(" · ")}</p>
  )}

  <div class="layout">
    <div class="col-left">
    <div class="card card-images">
      <h2>Images</h2>
      <div class="gallery">
        {data.images.map((image, i) => (
          <img
            src={image}
            alt={data.images.length > 1 ? `${creationAlt} — photo ${i + 1} of ${data.images.length}` : creationAlt}
            class="gallery-thumb"
            loading={i === 0 ? "eager" : "lazy"}
            decoding="async"
          />
        ))}
      </div>
    </div>

    {data.description.text && (
      <div class="card card-description">
        <h2>Description</h2>
        <p class="description-text" set:html={data.description.html} />
      </div>
    )}

    {yarnTiles.length > 0 && (
      <div class="card card-yarn">
        <h2>Yarns used</h2>
        <div class="yarn-grid">
          {yarnTiles.map((yarn) => {
            const Tag = yarn.link ? "a" : "div";
            return (
              <Tag class="yarn-tile" title={yarn.description} {...(yarn.link ? { href: yarn.link, target: "_blank", rel: "noopener noreferrer" } : {})}>
                <div class="swatch" class:list={{ "swatch-bordered": isWhite(yarn.hex) }} style={`background-color: ${yarn.hex ?? "var(--accent)"}`}>
                  {yarn.image && (
                    <img
                      src={yarn.image}
                      alt=""
                      onerror="this.nextElementSibling?.removeAttribute('hidden'); this.remove()"
                    />
                  )}
                  {/* Always rendered, but hidden while the real photo is showing —
                      the photo's onerror above reveals this if it fails to load
                      at runtime (e.g. a dead hotlink), same fallback as when no
                      image URL was ever recorded for this color. */}
                  <img
                    class="swatch-icon"
                    class:list={{ "swatch-icon-dark": isWhite(yarn.hex) }}
                    src="/images/icons/yarn.svg"
                    alt=""
                    hidden={!!yarn.image}
                  />
                </div>
                <div class="yarn-titles">
                  {yarn.type && <span class="type-chip-small">{yarn.type}</span>}
                  <span class="color-name">{yarn.colorName}</span>
                  <span class="line-name">{yarn.lineName}</span>
                </div>
              </Tag>
            );
          })}
        </div>
      </div>
    )}
    </div>

    <div class="col-right">
    <div class="pattern-social-row">
    <div class="card card-info">
      <h2>Info</h2>
      <ul class="info-list">
        {data.date && (
          <li>
            <span class="icon mask-icon" style="mask-image: url(/images/icons/calendar.svg); -webkit-mask-image: url(/images/icons/calendar.svg);"></span>
            {data.date.toLocaleDateString()}
          </li>
        )}
        {data.hoursSpent && (
          <li>
            <span class="icon mask-icon" style="mask-image: url(/images/icons/clock.svg); -webkit-mask-image: url(/images/icons/clock.svg);"></span>
            {data.hoursSpent < 1 ? `${Math.round(data.hoursSpent * 60)}m` : `${data.hoursSpent}h`}
          </li>
        )}
        {data.hookSize && (
          <li>
            <span class="icon mask-icon" style="mask-image: url(/images/icons/hook.svg); -webkit-mask-image: url(/images/icons/hook.svg);"></span>
            {data.hookSize}
          </li>
        )}
      </ul>

      {(typeChipIds.length > 0 || effectiveTags.length > 0) && (
        <div class="tags-row">
          {typeChipIds.map((tag) => (
            <TagChip id={tag} taxonomy={typesTaxonomy} />
          ))}
          {effectiveTags.map((tag) => (
            <TagChip id={tag} taxonomy={taxonomy} />
          ))}
        </div>
      )}
    </div>

    <div class="card card-designer">
      <DifficultyChip difficulty={data.difficulty} />
      <h2>Pattern</h2>
      <ul class="designer-list">
        {patternCredits.map((group) => (
          <li class="pattern-credit">
            <div class="credit-name">
              {group.creator === siteName
                ? <img class="icon credit-logo" src="/images/Lilis-Crochethings-thumb.webp" alt="" />
                : <span class="icon mask-icon" style="mask-image: url(/images/icons/person.svg); -webkit-mask-image: url(/images/icons/person.svg);"></span>}
              {group.creator
                ? (group.creatorLink
                  ? <SmartLink href={group.creatorLink}>{group.creator}</SmartLink>
                  : group.creator)
                : "Unknown"}
            </div>
            <ul class="pattern-items">
              {group.items.map((item) => {
                // A self-designed pattern with no platform set (e.g. "pattern
                // coming soon", no link yet) shouldn't fall back to the
                // generic website globe — the document icon reads as "this
                // is an original design" instead of implying an external site.
                // An explicit platform (if self-published somewhere later)
                // still wins over this.
                const platform = item.platform ?? (group.creator === siteName ? "pattern" : "website");
                // "pattern"/"website" are plain single-color glyphs (not real
                // brand artwork like Etsy/YouTube/etc.), so they're tinted via
                // the site's usual mask-icon + var(--primary) technique —
                // otherwise they'd stay frozen at whatever color is baked
                // into the SVG file, out of sync with dark mode's --primary.
                const icon = MASK_TINTED_PLATFORMS.has(platform) ? (
                  <span class="platform-icon-slot">
                    <span
                      class="platform-icon mask-icon"
                      style={`mask-image:url(${PLATFORM_ICONS[platform]}); -webkit-mask-image:url(${PLATFORM_ICONS[platform]});`}
                    ></span>
                  </span>
                ) : (
                  <span class="platform-icon-slot">
                    <img
                      class="platform-icon"
                      class:list={{ rounded: ROUNDED_PLATFORMS.has(platform) }}
                      src={PLATFORM_ICONS[platform]}
                      alt=""
                    />
                  </span>
                );
                return (
                  <li class="pattern-item">
                    {item.link ? (
                      <SmartLink class="pattern-link" href={item.link}>
                        {icon}
                        {item.name}
                      </SmartLink>
                    ) : (
                      <>
                        {icon}
                        {item.name}
                      </>
                    )}
                  </li>
                );
              })}
            </ul>
          </li>
        ))}
      </ul>
    </div>

    {(data.instagramLink || data.facebookLink || data.pinterestLink) && (
      <div class="card card-socials">
        <h2>Save on</h2>
        <ul class="socials-list">
          {data.instagramLink && (
            <li>
              <SmartLink href={data.instagramLink}>
                <img src="/images/socials/instagram.webp" alt="" />
                Instagram
              </SmartLink>
            </li>
          )}
          {data.facebookLink && (
            <li>
              <SmartLink href={data.facebookLink}>
                <img src="/images/socials/facebook.webp" alt="" />
                Facebook
              </SmartLink>
            </li>
          )}
          {data.pinterestLink && (
            <li>
              <SmartLink href={data.pinterestLink}>
                <img src="/images/socials/pinterest.webp" alt="" />
                Pinterest
              </SmartLink>
            </li>
          )}
        </ul>
      </div>
    )}
    </div>

    {similar.length > 0 && (
      <div class="card card-similar">
        <h2>See also</h2>
        <div class="similar-grid">
          {similar.map((c) => (
            <CreationCard creation={c} typesTaxonomy={typesTaxonomy} />
          ))}
        </div>
      </div>
    )}
    </div>
  </div>

  <LightboxChrome id="lightbox">
    <LightboxStage>
      <div class="lightbox-frame" id="lightbox-frame">
        <img id="lightbox-img" src="" alt="" />
      </div>
    </LightboxStage>
  </LightboxChrome>
</BaseLayout>

<script>
  import { initLightboxChrome } from "../../lib/lightboxChrome";

  const lightbox = document.getElementById("lightbox");
  const lightboxFrame = document.getElementById("lightbox-frame") as HTMLElement;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const thumbs = Array.from(document.querySelectorAll<HTMLImageElement>(".gallery-thumb"));

  const chrome = lightbox
    ? initLightboxChrome({
        overlay: lightbox,
        frame: lightboxFrame,
        img: lightboxImg,
        items: thumbs.map((thumb) => ({ src: thumb.src, alt: thumb.alt })),
        freezeFrameSize: true,
      })
    : null;

  thumbs.forEach((thumb, index) => {
    thumb.addEventListener("click", () => chrome?.open(index));
  });
</script>

<style>
@import "../../styles/breakpoints.css";

.breadcrumbs {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-bottom: 1rem;
  font-family: "Quicksand", sans-serif;
  font-size: 0.9rem;
}

.breadcrumbs a {
  color: var(--primary);
}

.breadcrumbs a:hover {
  text-decoration: underline;
}

.breadcrumbs [aria-current="page"] {
  color: var(--primary);
  font-weight: bold;
}

.breadcrumb-sep {
  color: var(--muted-text);
}

.also-known-as {
  margin: -0.75rem 0 1.25rem;
  font-family: "Quicksand", sans-serif;
  font-size: 0.9rem;
  color: var(--primary);
}

.layout {
  display: grid;
  grid-template-columns: 1fr var(--sidebar-width);
  gap: 1.5rem;
  align-items: start;
}

.col-left, .col-right {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.card {
  background: var(--surface);
  border: 1px solid var(--card-border);
  border-radius: 16px;
  box-shadow: 0 calc(4px * var(--shadow-blur-scale, 1)) calc(12px * var(--shadow-blur-scale, 1)) rgba(var(--shadow-color), calc(0.08 * var(--shadow-alpha-scale)));
  padding: 1.5rem;
}

.card h2 {
  margin-bottom: 0.75rem;
}

.card-images { order: 1; }
.card-info { order: 2; }
.card-description { order: 3; }
.card-designer { order: 4; position: relative; }
.pattern-social-row { display: contents; }
.card-socials { order: 5; }
.card-yarn { order: 6; }
.card-similar { order: 7; }

.card-yarn, .card-socials, .card-info, .card-designer {
  font-family: "Lili Love", cursive;
}

.description-text {
  white-space: pre-line;
  font-family: "Quicksand", sans-serif;
  font-size: 1rem;
  color: var(--text);
  margin: 0;
}

/* description.html is injected via set:html (raw string content), so any
   <a> inside never gets Astro's scoped-style data attribute — a plain
   ".description-text a" selector silently fails to match it and this rule
   never actually applied. */
.description-text :global(a) {
  color: var(--primary);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
}

.gallery img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 10px;
}

.gallery-thumb {
  cursor: var(--cursor-pointer);
}

/* <LightboxChrome>/<LightboxStage> render the shared .lb-overlay/.lb-inner/
   .lb-stage/.lb-nav/.lb-close markup from child components — Astro scoped
   styles only apply to a file's own template, so this page's own layout
   (centering, padding) needs :global() to reach into them. Scoped by the
   #lightbox id (not just the bare class) because Astro appends a
   [data-astro-cid-*] attribute to the component's own scoped rules, which
   otherwise out-specifies a plain :global(.lb-overlay) class selector — an
   id selector reliably wins regardless. */
:global(#lightbox.lb-overlay) {
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

/* Rounding/clipping/shadow live here, one level in from .lb-stage, rather
   than on the <img> directly — otherwise the outgoing/incoming pair would
   read as two separately-rounded images sliding past each other instead of
   one framed window with the picture moving inside it. Sized to shrink-wrap
   the image normally; only frozen to a fixed px size (via JS) for the
   duration of a slide, since photos here vary in aspect ratio and the
   sliding pair needs a stable shared box to animate within. */
.lightbox-frame {
  position: relative;
  display: flex;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 calc(8px * var(--shadow-blur-scale, 1)) calc(30px * var(--shadow-blur-scale, 1)) rgba(var(--shadow-color), calc(0.5 * var(--shadow-alpha-scale)));
}

.lightbox-frame img {
  display: block;
  max-width: 80vw;
  max-height: 85vh;
  object-fit: contain;
}

.socials-list {
  list-style: none;
  padding: 0;
  margin: 1rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  font-size: 1rem;
}

.socials-list a {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--primary);
}

.socials-list a:hover {
  text-decoration: underline;
  text-underline-offset: 2px;
}

.socials-list img {
  width: 26px;
  height: 26px;
  border-radius: 6px;
}

.yarn-grid {
