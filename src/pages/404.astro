---
import BaseLayout from '../layouts/BaseLayout.astro';
import SmartLink from '../components/SmartLink.astro';
---

<BaseLayout
  title="Page not found"
  description="This page doesn't exist — head back to Lili's Crochethings homepage."
>
  <div class="not-found">
    <span class="not-found-icon mask-icon" aria-hidden="true"></span>
    <h1>Oops, tangled thread!</h1>
    <p>We couldn't find the page you were looking for.</p>
    <SmartLink href="/" class="home-button">Back to home</SmartLink>

    <div id="not-found-suggestions" class="not-found-suggestions" hidden>
      <h2>Did you mean...</h2>
      <div class="suggestions-list" id="not-found-suggestions-list"></div>
    </div>
  </div>
</BaseLayout>

<script>
  import { renderResultTile, type SearchDoc } from '../lib/search';
  import { findSimilarPages } from '../lib/notFound';

  const suggestionsSection = document.getElementById('not-found-suggestions');
  const suggestionsList = document.getElementById('not-found-suggestions-list');

  async function run() {
    if (!suggestionsSection || !suggestionsList) return;

    const docs: SearchDoc[] = await fetch('/search-index.json').then((res) => res.json());
    const matches = findSimilarPages(decodeURIComponent(window.location.pathname), docs);
    if (!matches.length) return;

    suggestionsList.innerHTML = matches
      .map((match) =>
        match.image
          ? renderResultTile(match, '')
          : `<a class="static-page-link" href="${match.href}">${match.title}</a>`
      )
      .join('');
    suggestionsSection.hidden = false;
  }

  run();
</script>

<style>
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.5rem;
  padding: 4rem 1rem;
}

.not-found-icon {
  width: 72px;
  height: 72px;
  margin-bottom: 0.5rem;
  background-color: var(--primary);
  mask-image: url(/images/icons/yarn.svg);
  -webkit-mask-image: url(/images/icons/yarn.svg);
}

.not-found h1 {
  margin-bottom: 0;
}

.not-found p {
  font-family: "Quicksand", sans-serif;
  color: var(--text);
  margin: 0 0 1rem;
}

.home-button {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  border-radius: 999px;
  background: var(--primary);
  color: var(--on-primary);
  font-family: "Quicksand", sans-serif;
  font-weight: bold;
  text-decoration: none;
  box-shadow: 0 calc(4px * var(--shadow-blur-scale, 1)) calc(12px * var(--shadow-blur-scale, 1)) rgba(var(--shadow-color), calc(0.2 * var(--shadow-alpha-scale)));
  transition: transform 0.2s ease;
}

.home-button:hover {
  transform: scale(1.05);
}

.not-found-suggestions {
  width: 100%;
  max-width: 560px;
  margin-top: 2rem;
  text-align: left;
}

.not-found-suggestions h2 {
  text-align: center;
  color: var(--primary);
  margin-bottom: 1rem;
}

.suggestions-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.static-page-link {
  display: block;
  padding: 0.9rem 1.1rem;
  border-radius: 16px;
  background: var(--surface);
  border: 1px solid var(--card-border);
  box-shadow: 0 calc(4px * var(--shadow-blur-scale, 1)) calc(12px * var(--shadow-blur-scale, 1)) rgba(var(--shadow-color), calc(0.08 * var(--shadow-alpha-scale)));
  color: var(--primary);
  font-family: "Quicksand", sans-serif;
  font-weight: bold;
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

/* No hover-specific shadow bump in light mode (the resting shadow above
   already carries it) — this exists for dark mode, where the resting
   shadow is zeroed out and hovering would otherwise show nothing at all. */
.static-page-link:hover {
  transform: scale(1.02);
  box-shadow: 0 calc(10px * var(--inner-hover-blur-scale, 1)) calc(24px * var(--inner-hover-blur-scale, 1)) rgba(var(--inner-shadow-color), 0.15);
}
</style>
