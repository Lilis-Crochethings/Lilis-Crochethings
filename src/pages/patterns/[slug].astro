   are already direct children at every viewport size): DOM order alone
   would stack col-left's cards (Images, Description, Materials) before
   Info, so explicit order interleaves everything into the requested
   Info -> Images -> Description -> Materials -> Instructions ->
   Abbreviations sequence instead. Same technique as creations/[slug].astro. */
:global(.card-images) { order: 2; }
:global(.card-description) { order: 3; }
.card-materials { order: 4; }
:global(.pattern-instructions) { order: 5; }

/* Info, About Me, Pattern makes, See also, and the sticky Abbreviations+
   Progress group all flow as one continuous column now (no more splitting
   Info off into its own grid row) — reset to display:contents at mobile/
   tablet-portrait below, exposing all of them as their own ordered flex
   items alongside Images/Description/etc., same as .col-left. */
.col-right {
  grid-column: 2;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

:global(.card-info) {
  order: 1;
}

/* Same order as Info — ties are broken by source order, so this (and
   Creations/Similar patterns below) still land directly under it once all
   four become direct flex children of .layout at mobile/tablet-only. */
:global(.card-about-me) {
  order: 1;
}

.card-creations, .card-similar-patterns {
  order: 1;
  font-family: "Lili Love", cursive;
}

.creations-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

/* Wraps the progress bar + Abbreviations so they're pinned as one unit,
   last inside .col-right (order: 2 — higher than the order: 1 group above
   it, since plain DOM order alone would otherwise put a same-order sticky
   item ahead of them by default). Sticks once scrolled to top: 1rem and
   keeps following the page all the way through Instructions/Congrats in
   .col-left, because .col-right itself (its sticky containing block) is
   stretched to match .col-left's full height — see .layout above — not
   just its own shorter content. Reset to a plain static flex item at
   mobile/tablet-portrait below, since a single stacked column has no
   side-by-side content for it to stay pinned alongside. */
.col-right-sticky {
  order: 2;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  position: sticky;
  /* Not var(--nav-height) — .nav is position: relative, not fixed, so it
     scrolls away like everything else above this column. By the time this
     column is actually stuck (scrolled far enough for its own top to reach
     the viewport edge), the navbar is long gone; offsetting by its height
     anyway left a permanent ~76px dead gap above Progress/Abbreviations
     for the rest of the scroll — same mistake the mobile mini progress bar
     had before it was fixed to top: 0 (see PatternProgressBar.astro). */
  top: 1rem;
}

