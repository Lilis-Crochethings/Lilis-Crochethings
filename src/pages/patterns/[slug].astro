---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CreationCard from '../../components/creations/CreationCard.astro';
import ImagesCard from '../../components/ImagesCard.astro';
import DescriptionCard from '../../components/DescriptionCard.astro';
import InfoCard from '../../components/InfoCard.astro';
import LightboxChrome from '../../components/LightboxChrome.astro';
import LightboxStage from '../../components/LightboxStage.astro';
import PatternInstructions from '../../components/patterns/PatternInstructions.astro';
import PatternProgressBar from '../../components/patterns/PatternProgressBar.astro';
import PatternAbbreviationsDrawer from '../../components/patterns/PatternAbbreviationsDrawer.astro';
import AboutMeCard from '../../components/patterns/AboutMeCard.astro';
import CongratsCard from '../../components/patterns/CongratsCard.astro';
import PatternCard from '../../components/patterns/PatternCard.astro';
import { getCollection } from "astro:content";
import { getEffectiveTags, getCreationAlt, getTagLabel } from "../../lib/tags";
import { formatHours } from "../../lib/time";
import { YARN_WEIGHT_LABELS } from "../../lib/yarnWeight";
import { resolveYarn } from "../../lib/yarn";
import { seededShuffle } from "../../lib/seededShuffle";

export async function getStaticPaths() {
  // Same cap as the creations detail page's own "See also" card.
  const USED_IN_LIMIT = 4;
  const SIMILAR_LIMIT = 4;

  const patterns = await getCollection("patterns");
  const creations = await getCollection("creations");

  return patterns.map((pattern) => {
    // A creation credits a self-designed pattern by linking straight to its
    // detail page (see e.g. bunny.yaml's `link: "/patterns/jumbo-bunny"") —
    // that internal link is already a stable, unambiguous key back to this
    // pattern, unlike its free-text item name (which a creation is free to
    // word differently, e.g. pluralized or shortened).
    // Most recent first, then capped — a popular pattern with many makes
    // shows its newest ones rather than an arbitrary/collection-order slice.
    const usedIn = creations
      .filter((creation) =>
        (creation.data.patterns ?? []).some((group) =>
          group.items.some((item) => item.link === `/patterns/${pattern.id}`)
        )
      )
      .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
      .slice(0, USED_IN_LIMIT);

    const others = patterns.filter((p) => p.id !== pattern.id);

    // Same scoring idea as the creations detail page's own "See also" card:
    // tags + subtypes count together (the type itself, "crochet"/
    // "embroidery", is too broad a signal on its own — every pattern of that
    // craft would get a free point of similarity regardless of subject),
    // plus a Jaccard-scaled color overlap so a fully-matching small palette
    // doesn't lose to a partially-matching large one. No creator/pattern-name
    // bonus here (unlike creations) — every entry in this collection is
    // already Lili's own pattern, so that signal has nothing to distinguish.
    const ownTags = new Set([...(pattern.data.tags ?? []), ...(pattern.data.subtypes ?? [])]);
    const ownColors = new Set(pattern.data.colors ?? []);

    function similarityScore(other: (typeof others)[number]): number {
      let score = 0;

      const otherTags = [...(other.data.tags ?? []), ...(other.data.subtypes ?? [])];
      score += otherTags.filter((tag) => ownTags.has(tag)).length;

      const otherColors = other.data.colors ?? [];
      const sharedColors = otherColors.filter((color) => ownColors.has(color)).length;
      const unionColors = new Set([...ownColors, ...otherColors]).size;
      if (unionColors > 0) score += sharedColors / unionColors;

      return score;
    }

    // Shuffle first (seeded per-pattern) so ties between equally-similar
    // patterns land in a stable-but-varied order instead of always favoring
    // whichever comes first in the collection.
    const similar = seededShuffle(others, pattern.id)
      .sort((a, b) => similarityScore(b) - similarityScore(a))
      .slice(0, SIMILAR_LIMIT);

    return {
      params: { slug: pattern.id },
      props: { pattern, usedIn, similar },
    };
  });
}

const { pattern, usedIn, similar } = Astro.props;
const data = pattern.data;

const taxonomyEntry = (await getCollection("tags"))[0];
const taxonomy = taxonomyEntry.data.tags;
const effectiveTags = getEffectiveTags(data.tags, taxonomy);

const typesEntry = (await getCollection("types"))[0];
const typesTaxonomy = typesEntry.data.types;
const typeChipIds = [data.type, ...(data.subtypes ?? [])];
const patternAlt = getCreationAlt(data.title, data.type, data.subtypes, typesTaxonomy);

const materialsEntry = (await getCollection("materials"))[0];
const materialsCatalog = materialsEntry.data.materials;
const materialTiles = (data.materials?.items ?? [])
  .map((id) => materialsCatalog.find((material) => material.id === id))
  .filter((material) => material !== undefined);
const patternYarns = data.materials?.yarns ?? [];
const patternSafetyEyes = data.materials?.safetyEyes ?? [];
// Every distinct hook size this pattern needs, in first-appearance order —
// shown as its own tile (like safety eyes) so a visitor doesn't have to dig
// through the yarn list to see what hooks they'll need.
const hookSizes = [...new Set(data.materials?.hooks ?? [])];
const hasMaterials = materialTiles.length > 0 || patternYarns.length > 0 || patternSafetyEyes.length > 0;

const yarnLinesEntry = (await getCollection("yarns"))[0];
const yarnLines = yarnLinesEntry.data.yarns;

// Each suggested yarn slot also doubles as a record of what Lili actually
// used, once it sets its own `yarn` field — a catalog reference (resolved
// via resolveYarn(), same helper a creation's own "Yarns used" card uses) or
// a one-off inline yarn. Resolved once per yarn here rather than in the
// markup below so the tile JSX stays plain field access.
const resolvedPatternYarns = patternYarns.map((yarn) => ({
  yarn,
  resolved: yarn.yarn ? resolveYarn(yarn.yarn, yarnLines) : null,
}));

// Same purpose as the creation detail page's identical helper — a light
// swatch needs a border to stay visible against the card background, and
// its yarn-ball fallback icon needs a darker tint instead of white.
function isWhiteHex(hex?: string): boolean {
  if (!hex) return false;
  const clean = hex.replace("#", "").toLowerCase();
  return clean === "fff" || clean === "ffffff";
}

const abbreviationsEntry = (await getCollection("abbreviations"))[0];
const abbreviationsCatalog = abbreviationsEntry.data.abbreviations;
// Kept in the order the pattern lists them (not the glossary's own order) —
// that's usually the order the abbreviations first show up in the
// instructions themselves.
const patternAbbreviations = (data.abbreviations ?? [])
  .map((id) => abbreviationsCatalog.find((abbr) => abbr.id === id))
  .filter((abbr) => abbr !== undefined);

const hasPatternInstructions = Boolean(data.pattern && data.pattern.length > 0);

const infoItems = [
  data.date && { icon: "/images/icons/calendar.svg", label: data.date.toLocaleDateString(), title: "Published" },
  data.lastModified && { icon: "/images/icons/last-modified.svg", label: data.lastModified.toLocaleDateString(), title: "Last updated" },
  data.hoursSpent && { icon: "/images/icons/clock.svg", label: formatHours(data.hoursSpent), title: "Time spent" },
  data.hookSize && { icon: "/images/icons/hook.svg", label: data.hookSize, title: "Hook size" },
].filter((item): item is { icon: string; label: string; title: string } => Boolean(item));

// Glossary entries are written lowercase in the yaml (natural to type) —
// capitalized here at render time rather than duplicating each label in
// two cases in the source data.
function capitalize(text: string): string {
  return text.charAt(0).toUpperCase() + text.slice(1);
}

function yarnTitle(name: string, amount?: string): string {
  return amount ? `${amount} of ${name}` : name;
}
// Second line under a yarn tile's title — the catalog line it's from (when
// resolved via its own `yarn` field) and the weight it's suggested in.
function yarnSubtitle(brand: string | undefined, weight: string | undefined): string {
  const weightLabel = weight ? YARN_WEIGHT_LABELS[weight] : null;
  return [brand, weightLabel].filter(Boolean).join(" · ");
}

const craftType = data.type;

const baseDescription = data.description?.text || `A free ${craftType} pattern for ${data.title} by Lili's Crochethings.`;

// Same reasoning as the creation detail page's identical line — the craft
// type is stated every time (not just the no-description fallback) so a
// cross-stitch pattern's page never reads as crochet-by-default to Google.
const typeLabels = typeChipIds.map((id) => getTagLabel(id, typesTaxonomy));
const craftDescription = `Craft: ${typeLabels.join(", ")}.`;
const tagLabels = effectiveTags.map((id) => getTagLabel(id, taxonomy));

const pageDescription = [
  baseDescription,
  craftDescription,
  tagLabels.length ? `Tags: ${tagLabels.join(", ")}.` : null,
  data.searchTerms?.length ? `Also known as: ${data.searchTerms.join(", ")}.` : null,
].filter(Boolean).join(" ");

const creativeWorkSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: data.title,
  description: pageDescription,
  image: data.images.map((image) => new URL(image, Astro.site).toString()),
  ...(data.date ? { dateCreated: data.date.toISOString().slice(0, 10) } : {}),
  ...(data.lastModified ? { dateModified: data.lastModified.toISOString().slice(0, 10) } : {}),
  ...(data.searchTerms?.length ? { alternateName: data.searchTerms } : {}),
  genre: typeLabels,
  ...(tagLabels.length ? { keywords: tagLabels } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Patterns", item: new URL("/patterns", Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: data.title, item: Astro.url.toString() },
  ],
};

// Same reasoning as the creation detail page's identical line — only the
// first searchTerm goes in the title (reused for og:title/twitter:title too),
// the full list is still exposed via the meta description and JSON-LD
// alternateName below.
const pageTitle = data.searchTerms?.length ? `${data.title} (${data.searchTerms[0]})` : data.title;
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={data.images[0]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(creativeWorkSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep" aria-hidden="true">/</span>
    <a href="/patterns">Patterns</a>
    <span class="breadcrumb-sep" aria-hidden="true">/</span>
    <span aria-current="page">{data.title}</span>
  </nav>

  <h1>{data.title}</h1>
  {data.searchTerms?.length && (
    <p class="also-known-as">{data.searchTerms.join(" · ")}</p>
  )}

  <p class="print-notice">
    This pattern is only viewable on {new URL("/patterns/" + pattern.id, Astro.site).toString()} — printing and saving as a PDF aren't supported. Please visit the site to follow along.
  </p>

  <div class="layout">
    <div class="col-left">
    <ImagesCard images={data.images} alt={patternAlt} />

    {data.description?.text && <DescriptionCard html={data.description.html} />}

    {hasMaterials && (
      <div class="card card-materials" data-pattern-slug={pattern.id}>
        <h2>Materials</h2>
        {(materialTiles.length > 0 || patternSafetyEyes.length > 0 || hookSizes.length > 0) && (
          <div class="materials-grid">
            {materialTiles.map((material) => (
              <div class="material-tile">
                <span class="material-icon-box">
                  <span class="material-icon mask-icon" style={`mask-image:url(${material.icon}); -webkit-mask-image:url(${material.icon});`}></span>
                </span>
                <span class="material-info">
                  <span class="material-label">{material.label}</span>
                </span>
              </div>
            ))}
            {patternSafetyEyes.map((eyes) => (
              <div class="material-tile">
                <span class="material-icon-box">
                  <span class="material-icon mask-icon" style="mask-image: url(/images/icons/eye.svg); -webkit-mask-image: url(/images/icons/eye.svg);"></span>
                </span>
                <span class="material-info">
                  <span class="material-label">{eyes.amount ? `${eyes.amount}x Safety eyes` : "Safety eyes"}</span>
                  <span class="material-sublabel">{eyes.size}</span>
                </span>
              </div>
            ))}
            {hookSizes.map((size) => (
              <div class="material-tile">
                <span class="material-icon-box">
                  <span class="material-icon mask-icon" style="mask-image: url(/images/icons/hook.svg); -webkit-mask-image: url(/images/icons/hook.svg);"></span>
                </span>
                <span class="material-info">
                  <span class="material-label">Crochet hook</span>
                  <span class="material-sublabel">{size}</span>
                </span>
              </div>
            ))}
            {resolvedPatternYarns.map(({ yarn, resolved }) => {
              const displayName = resolved?.colorName ?? yarn.name;
              const title = yarnTitle(displayName, yarn.amount);
              const subtitle = yarnSubtitle(resolved?.lineName, yarn.weight);
              const link = resolved?.link;
              const Tag = link ? "a" : "div";
              return (
                <Tag
                  class="material-tile yarn-material-tile"
                  data-yarn-id={yarn.id}
                  data-default-color-light={yarn.color.light}
                  data-default-color-dark={yarn.color.dark}
                  {...(link ? { href: link, target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {resolved ? (
                    <span class="used-yarn-swatch" class:list={{ "swatch-bordered": isWhiteHex(resolved.hex) }} style={`background-color:${resolved.hex ?? "var(--accent)"}`}>
                      {resolved.image && (
                        <img
                          src={resolved.image}
                          alt=""
                          onerror="this.nextElementSibling?.removeAttribute('hidden'); this.remove()"
                        />
                      )}
                      <img
                        class="used-yarn-swatch-icon"
                        class:list={{ "used-yarn-swatch-icon-dark": isWhiteHex(resolved.hex) }}
                        src="/images/icons/yarn.svg"
                        alt=""
                        hidden={!!resolved.image}
                      />
                    </span>
                  ) : (
                    <span class="yarn-swatch-box" style={`--swatch-color-light: ${yarn.color.light}; --swatch-color-dark: ${yarn.color.dark}`}>
                      <span class="yarn-swatch-icon mask-icon" style="mask-image: url(/images/icons/yarn.svg); -webkit-mask-image: url(/images/icons/yarn.svg);" aria-hidden="true"></span>
                    </span>
                  )}
                  <span class="used-yarn-titles">
                    {resolved?.type && <span class="type-chip-small">{resolved.type}</span>}
                    <span class="material-label">{title}</span>
                    <span class="material-sublabel" hidden={!subtitle}>{subtitle}</span>
                  </span>
                </Tag>
              );
            })}
          </div>
        )}
      </div>
    )}

    {hasPatternInstructions && <PatternInstructions pattern={pattern} />}
    </div>

    <div class="col-right">
    <InfoCard
      items={infoItems}
      typeChipIds={typeChipIds}
      effectiveTags={effectiveTags}
      typesTaxonomy={typesTaxonomy}
      taxonomy={taxonomy}
      difficulty={data.difficulty}
    />

    <AboutMeCard />

    {usedIn.length > 0 && (
      <div class="card card-creations">
        <h2>Pattern makes</h2>
        <div class="creations-grid">
          {usedIn.map((creation) => (
            <CreationCard creation={creation} typesTaxonomy={typesTaxonomy} />
          ))}
        </div>
      </div>
    )}

    {similar.length > 0 && (
      <div class="card card-similar-patterns">
        <h2>See also</h2>
        <div class="creations-grid">
          {similar.map((p) => (
            <PatternCard pattern={p} typesTaxonomy={typesTaxonomy} />
          ))}
        </div>
      </div>
    )}

    {(hasPatternInstructions || patternAbbreviations.length > 0) && (
      <div class="col-right-sticky">
        {patternAbbreviations.length > 0 && (
          <div class="card card-abbreviations">
            <h2>Abbreviations</h2>
            <dl class="abbr-table">
              {patternAbbreviations.map((abbr) => (
                <>
                  <dt class="abbr-key">{abbr.id.toUpperCase()}:</dt>
                  <dd class="abbr-meaning">{capitalize(abbr.label)}</dd>
                </>
              ))}
            </dl>
          </div>
        )}
        {hasPatternInstructions && <PatternProgressBar />}
      </div>
    )}
    </div>

    <CongratsCard outro={data.outro} />
  </div>

  <div id="copy-block-toast" class="copy-block-toast" role="status" aria-live="polite">
    Printing and copying are disabled for this pattern.
  </div>

  {hasPatternInstructions && patternAbbreviations.length > 0 && (
    <PatternAbbreviationsDrawer abbreviations={patternAbbreviations} />
  )}

  <LightboxChrome id="lightbox">
    <LightboxStage>
      <div class="lightbox-frame" id="lightbox-frame">
        <img id="lightbox-img" src="" alt="" />
      </div>
    </LightboxStage>
  </LightboxChrome>
</BaseLayout>

<script>
  import { initLightboxChrome } from "../../lib/lightboxChrome";

  const lightbox = document.getElementById("lightbox");
  const lightboxFrame = document.getElementById("lightbox-frame") as HTMLElement;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const thumbs = Array.from(document.querySelectorAll<HTMLImageElement>(".gallery-thumb"));

  const chrome = lightbox
    ? initLightboxChrome({
        overlay: lightbox,
        frame: lightboxFrame,
        img: lightboxImg,
        items: thumbs.map((thumb) => ({ src: thumb.src, alt: thumb.alt })),
        freezeFrameSize: true,
      })
    : null;

  thumbs.forEach((thumb, index) => {
    thumb.addEventListener("click", () => chrome?.open(index));
  });
</script>

<script>
  // Deterrents only, not real protection — the pattern still has to be sent
  // to the browser as plain HTML for a legitimate visitor to read it, so
  // anyone determined (view-source, disabling JS, a screenshot) gets past
  // this regardless. This just stops the casual "Ctrl+P to PDF" or
  // right-click-copy path; the @media print rule below is the actual
  // backstop for the browser's own Print menu, which never fires a JS event
  // this script could intercept.
  const protectedArea = document.querySelector(".layout");
  const toast = document.getElementById("copy-block-toast");
  let toastTimer: number | undefined;

  function showToast() {
    if (!toast) return;
    toast.classList.add("visible");
    window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => toast.classList.remove("visible"), 3000);
  }

  document.addEventListener("keydown", (e) => {
    const key = e.key.toLowerCase();
    if ((e.ctrlKey || e.metaKey) && (key === "p" || key === "s")) {
      e.preventDefault();
      showToast();
    }
  });

  protectedArea?.addEventListener("contextmenu", (e) => {
    e.preventDefault();
    showToast();
  });

  protectedArea?.addEventListener("copy", (e) => {
    e.preventDefault();
    showToast();
  });
</script>

<script>
  import { readYarnOverrides, isLightHex } from "../../lib/yarnOverrides";

  // The main tile swatch shows a yarn's real light/dark pair via CSS custom
  // properties (see .yarn-swatch-box in this file's <style>, which switches
  // between them the same way ColoredSegments.astro's instruction-text spans
  // do) — a visitor's color override (set on PatternSettingsCard.astro) is a
  // single hex, so it's passed as both light and dark here to display the
  // same either way.
  //
  // The overlay icon's contrast (white vs. black) is decided the same
  // theme-reactive way, via --icon-bg-light/-dark custom properties (see
  // .yarn-swatch-icon below) rather than a class toggled once here — a class
  // picked from the *current* theme would go stale the instant a visitor
  // toggles the theme afterward, since nothing re-runs this function on that
  // toggle. Precomputing both variants up front and letting CSS pick means
  // it can never go stale.
  function setSwatchColorPair(box: HTMLElement | null, light: string, dark: string) {
    if (!box) return;
    box.style.setProperty("--swatch-color-light", light);
    box.style.setProperty("--swatch-color-dark", dark);
    const icon = box.querySelector<HTMLElement>(".yarn-swatch-icon");
    icon?.style.setProperty("--icon-bg-light", isLightHex(light) ? "black" : "white");
    icon?.style.setProperty("--icon-bg-dark", isLightHex(dark) ? "black" : "white");
  }

  document.querySelectorAll<HTMLElement>(".card-materials").forEach((card) => {
    const slug = card.dataset.patternSlug;
    if (!slug) return;

    function repaint() {
      const overrides = readYarnOverrides(slug!);
      card.querySelectorAll<HTMLElement>(".yarn-material-tile").forEach((tile) => {
        const yarnId = tile.dataset.yarnId;
        if (!yarnId) return;
        // Only present on a tile with no resolved "real" yarn (see the
        // markup below) — a resolved tile shows that yarn's actual photo/
        // hex instead, which a visitor's instruction-text color override
        // has no bearing on.
        const box = tile.querySelector<HTMLElement>(".yarn-swatch-box");
        const overrideHex = overrides[yarnId]?.hex;
        if (overrideHex) {
          setSwatchColorPair(box, overrideHex, overrideHex);
        } else {
          setSwatchColorPair(box, tile.dataset.defaultColorLight ?? "", tile.dataset.defaultColorDark ?? "");
        }
      });
    }

    repaint();
    document.addEventListener("pattern-yarn-override-change", (e) => {
      const detail = (e as CustomEvent<{ slug?: string }>).detail;
      if (detail?.slug !== slug) return;
      repaint();
    });
  });
</script>

<style>
@import "../../styles/breakpoints.css";

.breadcrumbs {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-bottom: 1rem;
  font-family: "Quicksand", sans-serif;
  font-size: 0.9rem;
}

.breadcrumbs a {
  color: var(--primary);
}

.breadcrumbs a:hover {
  text-decoration: underline;
}

.breadcrumbs [aria-current="page"] {
  color: var(--primary);
  font-weight: bold;
}

.breadcrumb-sep {
  color: var(--muted-text);
}

.also-known-as {
  margin: -0.75rem 0 1.25rem;
  font-family: "Quicksand", sans-serif;
  font-size: 0.9rem;
  color: var(--primary);
}

/* Hidden on screen, shown only under @media print below — the actual
   backstop against "save as PDF" via the browser's own Print menu, which
   (unlike Ctrl+P/Cmd+P) never fires a JS event the script above could
   intercept. Text selection/copy on the pattern content is also blocked in
   the print stylesheet's scope below, alongside this notice. */
.print-notice {
  display: none;
}

.copy-block-toast {
  position: fixed;
  left: 50%;
  bottom: 1.5rem;
  transform: translate(-50%, 10px);
  background: var(--primary);
  color: var(--on-primary);
  font-family: "Quicksand", sans-serif;
  font-weight: bold;
  font-size: 0.9rem;
  padding: 0.75rem 1.25rem;
  border-radius: 999px;
  box-shadow: 0 calc(4px * var(--shadow-blur-scale, 1)) calc(12px * var(--shadow-blur-scale, 1)) rgba(var(--shadow-color), calc(0.25 * var(--shadow-alpha-scale)));
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
  z-index: 900;
}

.copy-block-toast.visible {
  opacity: 1;
  transform: translate(-50%, 0);
}

@media print {
  :global(nav),
  :global(.site-footer),
  :global(#scroll-to-top) {
    display: none !important;
  }

  .breadcrumbs,
  .also-known-as,
  .layout {
    display: none !important;
  }

  .print-notice {
    display: block;
    font-family: "Quicksand", sans-serif;
  }
}

/* Casual deterrent, not real protection (see the script above) — makes
   select-and-copy a little less convenient on the pattern's own materials/
   instructions content, without touching the rest of the page (nav, Info,
   About Me, ...). */
.card-materials,
:global(.pattern-instructions) {
  -webkit-user-select: none;
  user-select: none;
}

/* Two plain grid columns, one flowing item each — no explicit rows. Left
   (Images/Description/Materials/Instructions) is the tall column; right
   (Info/About Me/Pattern makes/See also/the sticky Abbreviations+Progress
   group) is naturally much shorter. Grid items default to align-items:
   stretch (not overridden here the way it used to be), so .col-right's own
   box stretches to match .col-left's full height even though its content
   doesn't fill it — that stretched box is what gives .col-right-sticky
   below room to keep traveling (and staying stuck) all the way down through
   Instructions, instead of unsticking the moment its own short content runs
   out. Congrats is a third item (see below), column-1-width only, that
   auto-places into its own row underneath .col-left once it's done, rather
   than living inside it — it's the closing note for the pattern itself, not
   part of the sticky Progress card's bounds. */
.layout {
