---
import { parse } from "yaml";
import socialsRaw from "../data/socials.yaml?raw";
import "../styles/global.css";
import { getCollection } from "astro:content";

type LinkEntry = { name: string; href: string; icon: string; newTab?: boolean };
type SocialsConfig = {
  icons: Record<string, { src: string; pad?: number; radius?: string }>;
  socials: LinkEntry[];
  contacts: LinkEntry[];
};

const { icons, socials, contacts } = parse(socialsRaw) as SocialsConfig;

const pagesEntry = (await getCollection("pages"))[0];
const { title, description } = pagesEntry.data.socials;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL("/images/Lilis-Crochethings.webp", Astro.site);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lili's Crochethings" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
  </head>

  <body class="socials-body">
    <main class="card">
      <h1 class="brand">Lili's Crochethings</h1>

      <div class="avatar">
        <img src="/images/Lilis-Crochethings-thumb.webp" alt="Lili's Crochethings" />
      </div>

      <h2 class="section-title">Socials</h2>
      <div class="links">
        {socials.map((s) => (
          <a class="link-pill" href={s.href} target={s.newTab ? "_blank" : undefined} rel={s.newTab ? "noopener noreferrer" : undefined}>
            <span class="badge" style={`padding:${icons[s.icon].pad ?? 0}px`}>
              <img src={icons[s.icon].src} alt="" style={`border-radius:${icons[s.icon].radius ?? 0}`} />
            </span>
            <span>{s.name}</span>
          </a>
        ))}
      </div>

      <h2 class="section-title">Contact</h2>
      <div class="links">
        {contacts.map((c) => (
          <a class="link-pill" href={c.href} target={c.newTab ? "_blank" : undefined} rel={c.newTab ? "noopener noreferrer" : undefined}>
            <span class="badge" style={`padding:${icons[c.icon].pad ?? 0}px`}>
              <img src={icons[c.icon].src} alt="" style={`border-radius:${icons[c.icon].radius ?? 0}`} />
            </span>
            <span>{c.name}</span>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>

<style>
  .socials-body {
    font-family: "Lili Love", Georgia, serif;
    background: var(--background);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    font-size: 1.1rem;
  }

  .card {
    width: 100%;
    max-width: 420px;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .brand {
    font-size: 2rem;
    text-align: center;
    color: var(--primary);
    margin: 0 0 0.5rem;
  }

  .avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-title {
    font-size: 1.5rem;
    color: var(--primary);
    margin: 1rem 0 0.25rem;
  }

  .links {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .link-pill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    box-sizing: border-box;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--card-border);
    box-shadow: 0 calc(4px * var(--shadow-blur-scale, 1)) calc(12px * var(--shadow-blur-scale, 1)) rgba(var(--shadow-color), calc(0.2 * var(--shadow-alpha-scale)));
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  /* Hover shadow uses --inner-shadow-color/--inner-hover-blur-scale (not the
     plain --shadow-color/--shadow-alpha-scale the resting shadow above
     uses) — those are pinned to black/0 in dark mode so this reads as
     "nothing" at rest there, but hovering it should still give some
     visible feedback: a tight white glow, same as inner tiles get. */
  .link-pill:hover {
    transform: scale(1.03);
    box-shadow: 0 calc(8px * var(--inner-hover-blur-scale, 1)) calc(20px * var(--inner-hover-blur-scale, 1)) rgba(var(--inner-shadow-color), 0.15);
  }

  .badge {
    width: 28px;
    height: 28px;
    min-width: 28px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
