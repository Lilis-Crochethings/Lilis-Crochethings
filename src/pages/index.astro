---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutCard from '../components/main/AboutCard.astro';
import PatternsCard from '../components/main/PatternsCard.astro';
import CreationsCard from '../components/main/CreationsCard.astro';
import GalleryCard from '../components/main/GalleryCard.astro';
import { getCollection } from 'astro:content';
import { getEffectiveTags, getCreationAlt } from '../lib/tags';
import { buildHomePreview } from '../lib/homePreview';

const allCreations = (await getCollection('creations')).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);

const taxonomyEntry = (await getCollection('tags'))[0];
const taxonomy = taxonomyEntry.data.tags;

const typesEntry = (await getCollection('types'))[0];
const typesTaxonomy = typesEntry.data.types;

const pagesEntry = (await getCollection('pages'))[0];
const pageMeta = pagesEntry.data.home;

// Priority order: recently-uploaded creations first (same "New" badge
// window), then the hand-picked highlightedCreations list, then most-recent-
// by-date to fill any leftover slots — capped at 4 so the homepage card
// stays a preview (2x2 on tablet/desktop) rather than growing unbounded as
// more creations get added. The full set lives at /creations.
const creationPreviews = buildHomePreview(
  allCreations,
  (creation) => creation.id,
  (creation) => creation.data.uploadDate,
  pageMeta.highlightedCreations,
  4
).map((creation) => ({
  creation,
  effectiveTags: getEffectiveTags(creation.data.tags, taxonomy),
}));

// Same date-desc-then-title tiebreak as patterns/index.astro's own sort.
const allPatterns = (await getCollection('patterns')).sort((a, b) => {
  const dateDiff = (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0);
  if (dateDiff !== 0) return dateDiff;
  return a.data.title.localeCompare(b.data.title, undefined, { sensitivity: 'base' });
});
// Same "New" priority as creations above; patterns have no hand-picked
// highlight list, so that tier is simply empty.
const patternPreviews = buildHomePreview(
  allPatterns,
  (pattern) => pattern.id,
  (pattern) => pattern.data.uploadDate,
  [],
  4
).map((pattern) => ({
  pattern,
  effectiveTags: getEffectiveTags(pattern.data.tags, taxonomy),
}));

// Capped at 2 images per creation for the marquee — showing every image of
// every creation ballooned to 100+ <img> tags (doubled again for the
// seamless-loop duplicate), which only gets worse as the collection grows.
const MARQUEE_IMAGES_PER_CREATION = 2;
const galleryImages = allCreations.flatMap((creation) =>
  creation.data.images.slice(0, MARQUEE_IMAGES_PER_CREATION).map((image) => ({
    image,
    alt: getCreationAlt(creation.data.title, creation.data.type, creation.data.subtypes, typesTaxonomy),
  }))
);

// Lets Google optionally show a search box directly under the site's search
// result (a "sitelinks search box"), letting people search the site without
// leaving Google first. Google decides whether to actually render it — this
// just makes it possible. Belongs on the homepage specifically, not every
// page, per Google's own guidance for this markup.
const generalEntry = (await getCollection('general'))[0];

const aboutEntry = (await getCollection('about'))[0];
const { summaryBio } = aboutEntry.data;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url: Astro.site?.toString(),
  name: generalEntry.data.name,
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${new URL("/search", Astro.site)}?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};
---

<BaseLayout
  description={pageMeta.description}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} />

<div class="home-stack">
<AboutCard
  name="Lili"
  bio={summaryBio}
  image="/images/Lilis-Crochethings-thumb.webp"
/>

<PatternsCard items={patternPreviews} taxonomy={taxonomy} typesTaxonomy={typesTaxonomy} />

<CreationsCard items={creationPreviews} taxonomy={taxonomy} typesTaxonomy={typesTaxonomy} />

<GalleryCard creations={galleryImages} />
</div>

</BaseLayout>

<style>
.home-stack {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
</style>