---
// src/components/cards/PatternsCard.astro
import { toThumb } from "../../lib/images";
const { patterns } = Astro.props;
---

<a class="home-card" href="/patterns">
  <h2>Patterns <span class="coming-soon">Coming soon</span></h2>

  <div class="grid">
    {patterns.map((p: any) => (
      <div class="imgWrap">
        <img src={toThumb(p.image)} alt={p.title} loading="lazy" decoding="async" />
      </div>
    ))}
  </div>
</a>

<style>
@import "../../styles/breakpoints.css";

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 10px;
}

.imgWrap img {
  width: 100%;
  max-width: 150px;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 10px;
}

</style>