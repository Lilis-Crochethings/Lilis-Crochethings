---
// src/components/main/CreationsCard.astro
import CreationTile from "../creations/CreationTile.astro";
import type { TagCategory } from "../../lib/tags";
import type { CollectionEntry } from "astro:content";

interface Props {
  items: { creation: CollectionEntry<"creations">; effectiveTags: string[] }[];
  taxonomy: TagCategory[];
  typesTaxonomy: TagCategory[];
}

const { items, taxonomy, typesTaxonomy } = Astro.props;
---

<a class="home-card" href="/creations">
  <h2>Creations</h2>

  <div class="grid">
    {items.map(({ creation, effectiveTags }) => (
      <CreationTile creation={creation} effectiveTags={effectiveTags} taxonomy={taxonomy} typesTaxonomy={typesTaxonomy} />
    ))}
  </div>
</a>

<style>
@import "../../styles/breakpoints.css";

h2 {
  margin: 0 0 1rem;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

@media (--tablet-up) {
  .grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
</style>
