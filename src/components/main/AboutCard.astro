---
// src/components/cards/AboutCard.astro
const { name, bio, image } = Astro.props;
---

<a class="home-card" href="/about">
  <div class="profile">
    <img src={image} alt={name} />
    <h3>{name}</h3>
  </div>
  <h2>About me</h2>
  <div class="bio" set:html={bio.html} />
</a>

<style>
@import "../../styles/breakpoints.css";

/* Floated at the very top of the card — a sibling of h2, not nested under
   it — so "About me" sits next to the photo first, then the bio text
   continues wrapping around it below. Must come first in the DOM for the
   float to affect the siblings that follow it. The negative margin tucks
   it closer to the card's true top-right corner than its normal flow
   position would place it. */
.profile {
  float: right;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  margin: -0.75rem -0.75rem 0.75rem 1.5rem;
}

.bio {
  white-space: pre-line;
}

.bio :global(a) {
  color: var(--primary);
  text-decoration: underline;
  text-underline-offset: 2px;
}

img {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  object-fit: cover;
}

h2 {
  margin-top: 0;
}

@media (--mobile) {
  /* Reproduces the pre-float stacked layout (title, then centered photo,
     then bio) despite the DOM now putting .profile first — order moves the
     heading back in front, align-self opts it (and .bio) out of the
     container's own centering so they stay left-aligned/full-width like
     every other breakpoint, and only the photo+name block is centered. */
  .home-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  h2 {
    order: -1;
    align-self: stretch;
  }

  .bio {
    align-self: stretch;
  }

  .profile {
    float: none;
    margin: 0;
  }

  .profile h3 {
    margin: 0;
  }
}
</style>
