   override here so this is a no-op for them. */
.line-check:indeterminate {
  -webkit-appearance: none;
  appearance: none;
  background-color: transparent;
  border: none;
}

@media (--mobile) {
  .row-images {
    grid-template-columns: 1fr;
  }
}
