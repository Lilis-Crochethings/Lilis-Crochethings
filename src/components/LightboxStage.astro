---
// The prev/next nav buttons around a caller-supplied frame (the default
// slot — each page owns its own frame/img sizing). Sibling content (e.g.
// the gallery's info card) goes outside this component, inside
// <LightboxChrome>'s own slot alongside it.
---

<div class="lb-stage">
  <button type="button" class="lb-nav lb-prev" aria-label="Previous image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 5 8 12l7 7"/></svg>
  </button>
  <slot />
  <div class="lb-spinner" aria-hidden="true"></div>
  <button type="button" class="lb-nav lb-next" aria-label="Next image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<style>
.lb-stage {
  position: relative;
}

.lb-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border: none;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  color: white;
  cursor: var(--cursor-pointer);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.lb-nav svg {
  width: 22px;
  height: 22px;
}

.lb-nav:hover {
  background: rgba(255, 255, 255, 0.3);
}

.lb-nav.hidden {
  display: none;
}

/* Covers the still-visible previous/outgoing image while the next one is
   still being fetched — .lb-stage has no other in-flow child once the nav
   buttons are pulled out via absolute positioning, so inset:0 here lines up
   with the frame the caller put in the slot, not the wider button cluster. */
.lb-spinner {
  display: none;
  position: absolute;
  inset: 0;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.25);
  pointer-events: none;
  z-index: 2;
}

.lb-spinner::after {
  content: "";
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.35);
  border-top-color: #fff;
  animation: lb-spin 0.8s linear infinite;
}

.lb-stage.lb-loading .lb-spinner {
  display: flex;
}

@keyframes lb-spin {
  to { transform: rotate(360deg); }
}

@media (prefers-reduced-motion: reduce) {
  .lb-spinner::after {
    animation: none;
  }
}

.lb-prev {
  right: 100%;
  margin-right: 1.75rem;
}

.lb-next {
  left: 100%;
  margin-left: 1.75rem;
}
</style>
