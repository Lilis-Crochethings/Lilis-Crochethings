---
import { toThumb } from "../../lib/images";

const { image, alt, index, href } = Astro.props as {
  image: string;
  alt: string;
  index: number;
  href: string;
};
---

<a href={href} class="tile" data-gallery-index={index} aria-label={`View ${alt}`}>
  <img src={toThumb(image)} alt={alt} loading="lazy" decoding="async" />
</a>

<style>
.tile {
  display: block;
  width: 100%;
  margin: 0;
  padding: 0;
  border: none;
  background: none;
  font: inherit;
  text-align: left;
  text-decoration: none;
  color: inherit;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 calc(4px * var(--shadow-blur-scale, 1)) calc(12px * var(--shadow-blur-scale, 1)) rgba(var(--shadow-color), calc(0.08 * var(--shadow-alpha-scale)));
  cursor: var(--cursor-pointer);
  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}

.tile img {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
}

/* Hover shadow uses --inner-shadow-color/--inner-hover-blur-scale (not the
   plain --shadow-color/--shadow-alpha-scale the resting shadow above uses)
   — those are pinned to black/0 in dark mode so this tile reads as
   "nothing" at rest there, but hovering it should still give some visible
   feedback: a tight white glow, same as inner tiles get. */
.tile:hover {
  transform: scale(1.04);
  box-shadow: 0 calc(16px * var(--inner-hover-blur-scale, 1)) calc(32px * var(--inner-hover-blur-scale, 1)) rgba(var(--inner-shadow-color), 0.2);
}
</style>
