---
import { getCollection } from "astro:content";

const general = (await getCollection("general"))[0]; // TODO: improve, this is ugly
console.log(general);
---

<nav class="nav">
  <div class="logo">
    <img src="/images/Lilis-Crochethings.webp" alt="Profile pic" />
    <p>{general.data.name}</p>
  </div>

  <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">☰</button>

  <ul class="nav-links" id="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/creations">Creations</a></li>
    <li><a href="/patterns">Patterns</a></li>
    <li><a href="/about">About me</a></li>
  </ul>
</nav>

<script>
  const btn = document.getElementById("hamburger");
  const links = document.getElementById("nav-links");

  const closeMenu = () => {
    links?.classList.remove("open");
    btn?.setAttribute("aria-expanded", "false");
    if (btn) btn.textContent = "☰";
    document.body.classList.remove("nav-open");
  };

  btn?.addEventListener("click", () => {
    const isOpen = links?.classList.toggle("open");
    btn.setAttribute("aria-expanded", String(!!isOpen));
    btn.textContent = isOpen ? "✕" : "☰";
    document.body.classList.toggle("nav-open", !!isOpen);
  });

  links?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>

<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background: var(--accent);
  }

  .logo {
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  img {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid white;
  }

  .nav-links {
    display: flex;
    gap: 1rem;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    color: #333;
  }

  .hamburger {
    display: none;
    font-size: 1.5rem;
    background: none;
    border: none;
    z-index: 1001;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hamburger {
      display: block;
    }

    .nav-links {
      display: flex;
      visibility: hidden;
      opacity: 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      position: fixed;
      inset: 0;
      background: var(--accent);
      transition: opacity 0.2s ease;
      z-index: 1000;
    }

    .nav-links a {
      font-size: 1.5rem;
    }

    .nav-links.open {
      visibility: visible;
      opacity: 1;
    }
  }
</style>
