---
import TagChip from "./TagChip.astro";
import DifficultyChip from "./DifficultyChip.astro";
import TileCarousel from "../TileCarousel.astro";
import type { TagCategory } from "../../lib/tags";
import { stripDescriptionLinks } from "../../lib/description";

const { creation, effectiveTags = [], taxonomy, typesTaxonomy } = Astro.props as {
  creation: any;
  effectiveTags?: string[];
  taxonomy: TagCategory[];
  typesTaxonomy: TagCategory[];
};

const difficulty: string | undefined = creation.data.difficulty;
const type: string = creation.data.type;
const typeChipIds = [type, ...(creation.data.subtypes ?? [])];
const href = `/creations/${creation.id}`;
---

<div
  class="list-item-wrap"
  data-date={creation.data.date?.getTime() ?? 0}
  data-hours={creation.data.hoursSpent}
  data-title={creation.data.title}
  data-tags={effectiveTags.join(" ")}
  data-difficulty={difficulty}
  data-type={typeChipIds.join(" ")}
  data-colors={(creation.data.colors ?? []).join(" ")}
  data-yarn-types={(creation.data.yarnTypes ?? []).join(" ")}
>
  <div class="list-item" role="link" tabindex="0">
    <DifficultyChip difficulty={difficulty} hideOnMobile />
    <div class="thumb">
      <TileCarousel images={creation.data.images} alt={creation.data.title} href={href} />
    </div>
    <div class="body">
      <h2 class="title">{creation.data.title}</h2>
      {creation.data.description && <p class="preview">{stripDescriptionLinks(creation.data.description)}</p>}
      {(typeChipIds.length > 0 || effectiveTags.length > 0) && (
        <div class="tags">
          {typeChipIds.map((id) => (
            <TagChip id={id} taxonomy={typesTaxonomy} />
          ))}
          {effectiveTags.map((id) => (
            <TagChip id={id} taxonomy={taxonomy} />
          ))}
        </div>
      )}
    </div>
  </div>
</div>

<style>
.thumb {
  position: relative;
}

/* <TileCarousel> renders the shared .tile-carousel/.tc-* markup from a
   child component — Astro scoped styles only apply to a file's own
   template, so this row's smaller, inset nav buttons need :global() to
   reach into it. .thumb itself (global.css) already fixes the box size
   (132px, 92px on mobile) and clips to it, so the carousel just needs to
   fill that box. !important because Astro appends a [data-astro-cid-*]
   attribute to the component's own scoped rules, which for properties they
   both set (nav button width/height, in particular) otherwise out-
   specifies a plain :global() selector regardless of source order — even a
   two-class descendant selector like ".thumb .tc-nav" only ties with the
   component's own scoped specificity, it doesn't beat it. */
:global(.thumb .tile-carousel) {
  width: 100% !important;
  height: 100% !important;
}

:global(.thumb .tc-nav) {
  width: 26px !important;
  height: 26px !important;
  transform: scale(0.7) !important;
}

:global(.thumb .tc-nav svg) {
  width: 14px !important;
  height: 14px !important;
}

@media (hover: hover) and (pointer: fine) {
  :global(.thumb .tile-carousel:hover .tc-nav) {
    transform: scale(1) !important;
  }
}

:global(.thumb .tc-nav:focus-visible) {
  transform: scale(1) !important;
}
</style>

<script>
  document.querySelectorAll<HTMLElement>(".list-item-wrap").forEach((root) => {
    const listItem = root.querySelector<HTMLElement>(".list-item");
    const tcLink = root.querySelector<HTMLAnchorElement>(".tc-link");
    if (!listItem || !tcLink) return;

    // .list-item can't be a real <a> — <TileCarousel> already renders one
    // around the image, and nav buttons (real <button>s) can't nest inside
    // an anchor. Clicks/keyboard activation on the row's other content
    // (title, description, tags, chip) forward to that inner link; clicks
    // inside the carousel itself are already handled by its own <a> and nav
    // buttons.
    listItem.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest(".tile-carousel")) return;
      tcLink.click();
    });

    listItem.addEventListener("keydown", (e) => {
      if (e.key !== "Enter" && e.key !== " ") return;
      if ((e.target as HTMLElement).closest(".tile-carousel")) return;
      e.preventDefault();
      tcLink.click();
    });
  });
</script>
