---
import TileCarousel from "../TileCarousel.astro";
import { getCreationAlt, type TagCategory } from "../../lib/tags";

const { creation, typesTaxonomy } = Astro.props as {
  creation: any;
  typesTaxonomy: TagCategory[];
};
---

<TileCarousel
  images={creation.data.images}
  alt={getCreationAlt(creation.data.title, creation.data.type, creation.data.subtypes, typesTaxonomy)}
  href={`/creations/${creation.id}`}
/>

<style>
/* <TileCarousel> renders the shared .tile-carousel/.tc-* markup from a
   child component — Astro scoped styles only apply to a file's own
   template, so this tile's own square-card look (and its distinctive
   slide-in-from-the-edge nav buttons) needs :global() to reach into it.
   !important because Astro appends a [data-astro-cid-*] attribute to the
   component's own scoped rules, which for properties they both set (nav
   button transform, in particular) otherwise out-specifies a plain
   :global() class selector regardless of source order — unlike the
   lightbox pages, there's no natural per-instance id here to scope by
   instead (many tiles share one page). This component is only ever used
   inside creations/[slug].astro's .card-similar. Light mode gives it its
   own resting shadow same as always; dark mode drops that
   (--inner-rest-shadow-scale: 0) in favor of the outline below, since a
   shadow-on-shadow card-in-a-card doesn't read well there the way it does
   in light mode. Expanding on hover always gets a (bigger) shadow — in
   dark mode this is the only shadow it ever shows, a white glow mimicking
   the light-mode hover lift since a dark one wouldn't show up. */
:global(.tile-carousel) {
  /* On its own container (not just the <img>) so this box keeps a stable
     height even mid-slide, when the sliding image pair goes
     position:absolute and would otherwise collapse an aspect-ratio set
     only on them — see the height-chaining comment in TileCarousel.astro. */
  aspect-ratio: 1 / 1 !important;
  border: 1px solid var(--border-muted) !important;
  border-radius: 16px !important;
  box-shadow: 0 4px 12px rgba(var(--inner-shadow-color), calc(0.08 * var(--inner-rest-shadow-scale))) !important;
  overflow: hidden !important;
  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1) !important;
}

:global(.tile-carousel:hover) {
  box-shadow: 0 calc(16px * var(--inner-hover-blur-scale, 1)) calc(32px * var(--inner-hover-blur-scale, 1)) rgba(var(--inner-shadow-color), 0.2) !important;
  transform: scale(1.04) !important;
}

/* Slide-in-on-hover only makes sense where hover is a real, mouse-driven
   gesture — touch devices get swipe-to-flip instead (see TileCarousel's own
   script), so the buttons stay put off the edge there rather than being
   permanently stuck half-visible with nothing to trigger them. Keyboard
   focus still reveals them regardless of input type. */
:global(.tc-prev) {
  transform: translateX(-14px) !important;
}

:global(.tc-next) {
  transform: translateX(14px) !important;
}

@media (hover: hover) and (pointer: fine) {
  :global(.tile-carousel:hover .tc-prev),
  :global(.tile-carousel:hover .tc-next) {
    transform: translateX(0) !important;
  }
}

:global(.tc-prev:focus-visible),
:global(.tc-next:focus-visible) {
  transform: translateX(0) !important;
}
</style>
