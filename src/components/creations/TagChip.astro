---
import { findTag } from "../../lib/tags";
import type { TagCategory } from "../../lib/tags";
import { renderTagChip, type ChipSize } from "../../lib/chips";

interface Props {
  // Either resolve a tag/type id against a taxonomy...
  id?: string;
  taxonomy?: TagCategory[];
  // ...or render a chip directly from already-known label/icon/color (e.g.
  // a yarn type, which isn't part of the tag taxonomy at all).
  label?: string;
  icon?: string;
  color?: string;
  size?: ChipSize;
  class?: string;
}

const { id, taxonomy, label, icon, color, size, class: className } = Astro.props as Props;
const resolved = id !== undefined ? findTag(id, taxonomy ?? []) : undefined;

const html = renderTagChip(
  {
    label: resolved?.label ?? label ?? id ?? "",
    icon: resolved?.image ?? icon,
    color: resolved?.color ?? color,
  },
  { size, extraClass: className }
);
---

<Fragment set:html={html} />
